def example_usage():
    """Ejemplo de uso programático (sin CLI)"""
    print("📚 Ejemplo de uso programático\n")
    
    # Crear sistema
    system = BookAgentSystem(
        author_name="Ana Sabino",
        author_id="2026-0056"
    )
    
    # Crear libro
    print("1️⃣  Creando nuevo libro...")
    idea = "Quiero escribir una novela de misterio sobre una detective que resuelve crímenes en una ciudad distópica"
    result = system.start_new_book(idea)
    print(f"   ✅ Tipo: {result['type']}, Claridad: {result['clarity']}/10\n")
    
    # Estructurar
    print("2️⃣  Estructurando libro...")
    structure = system.structure_book()
    print(f"   ✅ {structure['chapter_count']} capítulos creados\n")
    
    # Generar capítulo
    print("3️⃣  Generando Capítulo 1...")
    chapter = system.generate_chapter(1)
    print(f"   ✅ {chapter['word_count']} palabras generadas\n")
    
    # Revisar estilo
    print("4️⃣  Revisando estilo...")
    review = system.review_chapter_style(1)
    print(f"   ✅ Score mejorado de {review['score_before']:.1f} a {review['score_after']:.1f}\n")
    
    # Ver progreso
    print("5️⃣  Progreso actual:")
    progress = system.get_book_progress()
    print(f"   📊 {progress['chapters_written']}/{progress['total_chapters']} capítulos")
    print(f"   📈 {progress['progress_percentage']:.1f}% completado\n")
 
# ========================================================================
# MAIN
# ========================================================================
 
def main():
    """Función principal"""
    if len(sys.argv) > 1 and sys.argv[1] == "example":
        # Modo ejemplo
        example_usage()
    else:
        # Modo interactivo
        cli = BookSystemCLI()
        cli.start()
 
if __name__ == "__main__":
    main()
